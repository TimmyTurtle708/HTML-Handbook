      "id": "b1",
      "title": "Header 頭圖",
      "desc": "123123123546",
      "code": "<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n  <tr><td align=\"center\">\n    <img src=\"header.jpg\" width=\"600\" style=\"display:block;\">\n  </td></tr>\n</table>"
    },
    {
      "id": "b2",
      "title": "CTA 按鈕",
      "desc": "號召行動按鈕，使用 table 確保 Outlook 相容",
      "code": "<table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n  <tr><td bgcolor=\"#d94f2b\" style=\"border-radius:6px;\">\n    <a href=\"#\" style=\"display:inline-block;padding:14px 32px;color:#fff;text-decoration:none;font-weight:700;\">立即購買</a>\n  </td></tr>\n</table>"
    },
    {
      "id": "b3",
      "title": "雙欄商品區",
      "desc": "左右並列的商品介紹，使用 table 雙欄",
      "code": "<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n  <tr>\n    <td width=\"290\" valign=\"top\">\n      <img src=\"p1.jpg\" width=\"290\" style=\"display:block;\">\n    </td>\n    <td width=\"20\"></td>\n    <td width=\"290\" valign=\"top\">\n      <img src=\"p2.jpg\" width=\"290\" style=\"display:block;\">\n    </td>\n  </tr>\n</table>"
    }
  ],
